# ============================================================================
#  logstash-aem-logs.config
#  Parses AEM (author/publish) and Dispatcher logs downloaded from Cloud Manager
#  and ships them to per-type Elasticsearch indices, alongside the existing
#  CDN pipeline (which is left untouched).
#
#  HOW IT DECIDES WHAT TO DO:
#   - Environment name  -> taken from the sub-folder:  aem-logs/<env>/...
#   - Which parser to use -> taken from the Cloud Manager log-type token in the
#     FILE NAME (aemaccess, aemrequest, aemerror, aemdispatcher, httpdaccess,
#     httpderror). KEEP that token in the filename or routing will miss.
#   - Tier (author/publish), program id, env id, pod -> parsed from the AEM
#     node id embedded in each log line (the most reliable signal).
#
#  WHERE TO PUT LOGS:
#     ELK/aem-logs/<env>/   e.g.  ELK/aem-logs/prod/
#     Drop ALL of that environment's AEM + Dispatcher files in the one folder,
#     e.g.  publish-aemaccess-2026-07-12.log
#           publish-aemerror-2026-07-12.log
#           publish-aemrequest-2026-07-12.log
#           dispatcher-httpdaccess-2026-07-12.log
#           dispatcher-aemdispatcher-2026-07-12.log
#           dispatcher-httpderror-2026-07-12.log
#     (Unzip any *.log.gz first - Logstash reads .log)
# ============================================================================

input {
  # (1) AEM Java / error log needs multiline handling because stack traces
  #     span several lines. A new event starts with a "dd.MM.yyyy " timestamp.
  file {
    path              => "/usr/share/logstash/data/aem-logs/**/*aemerror*.log"
    start_position    => "beginning"
    sincedb_path      => "/usr/share/logstash/data/aem-logs/.sincedb_aemerror"
    ecs_compatibility => disabled
    codec => multiline {
      pattern => "^%{MONTHDAY}\.%{MONTHNUM}\.%{YEAR} "
      negate  => true
      what    => "previous"
    }
  }

  # (2) Everything else is single-line. Exclude the aemerror files handled above.
  file {
    path              => "/usr/share/logstash/data/aem-logs/**/*.log"
    exclude           => ["*aemerror*"]
    start_position    => "beginning"
    sincedb_path      => "/usr/share/logstash/data/aem-logs/.sincedb_aem"
    ecs_compatibility => disabled
  }
}

filter {

  # ---- Strip Windows carriage returns so they don't land in the last field --
  mutate { gsub => ["message", "\r", ""] }

  # ---- Environment name from the sub-folder: aem-logs/<env>/<file> ----------
  grok {
    match          => { "path" => "aem-logs/%{DATA:aem_env_name}/%{GREEDYDATA:log_filename}" }
    tag_on_failure => []
  }

  # =========================================================================
  #  AEM access log  (*aemaccess*)  and  Apache/Dispatcher access log (*httpdaccess*)
  #  Same shape:  nodeId clientIp user timestamp "METHOD url HTTP/x" status bytes "ref" "ua"
  # =========================================================================
  if "aemaccess" in [path] or "httpdaccess" in [path] {
    grok {
      match => { "message" =>
        '%{NOTSPACE:node_id} %{NOTSPACE:client_ip} %{NOTSPACE:auth_user} %{HTTPDATE:log_timestamp}\s+"%{WORD:http_method} %{DATA:url} HTTP/%{NUMBER:http_version}" %{NUMBER:status:int} (?:%{NUMBER:bytes:int}|-) "%{DATA:referrer}" "%{DATA:user_agent}"'
      }
    }
    date { match => ["log_timestamp", "dd/MMM/yyyy:HH:mm:ss Z"] }
    if "httpdaccess" in [path] {
      mutate { add_field => { "log_type" => "dispatcher-access" } }
    } else {
      mutate { add_field => { "log_type" => "aem-access" } }
    }
  }

  # =========================================================================
  #  AEM request log  (*aemrequest*)
  #  Two line shapes: a ">" request-start line and a "<-" response line.
  #  The response line carries status + response time (the useful bit).
  # =========================================================================
  else if "aemrequest" in [path] {
    grok {
      match => { "message" => [
        '%{HTTPDATE:log_timestamp} \[%{NUMBER:request_id}\] > %{WORD:http_method} %{DATA:url} HTTP/%{NUMBER:http_version} \[%{DATA:node_id}\]',
        '%{HTTPDATE:log_timestamp} \[%{NUMBER:request_id}\] <- %{NUMBER:status:int} %{NOTSPACE:content_type} %{NUMBER:response_time_ms:int}ms \[%{DATA:node_id}\]'
      ] }
    }
    date { match => ["log_timestamp", "dd/MMM/yyyy:HH:mm:ss Z"] }
    mutate { add_field => { "log_type" => "aem-request" } }
  }

  # =========================================================================
  #  Dispatcher log  (*aemdispatcher*)
  #  [timestamp] [LEVEL] [nodeId] "METHOD url" status timems [farm] [action X] "host"
  #  "action X" is the dispatcher cache status (hit / miss / pass / none ...).
  # =========================================================================
  else if "aemdispatcher" in [path] {
    grok {
      match => { "message" =>
        '\[%{HTTPDATE:log_timestamp}\] \[%{WORD:disp_level}\] \[%{DATA:node_id}\] "%{WORD:http_method} %{DATA:url}" (?:%{NUMBER:status:int}|-) %{NUMBER:response_time_ms:int}ms \[%{DATA:farm}\] \[action %{WORD:cache_action}\] "%{DATA:host}"'
      }
    }
    date { match => ["log_timestamp", "dd/MMM/yyyy:HH:mm:ss Z"] }
    mutate { add_field => { "log_type" => "dispatcher" } }
  }

  # =========================================================================
  #  Apache HTTPD error log  (*httpderror*)
  #  Fri Jul 17 02:19:48.093820 2020 [module:level] [pid X:tid Y] [nodeId] msg
  # =========================================================================
  else if "httpderror" in [path] {
    grok {
      match => { "message" =>
        '(?<log_timestamp>%{DAY} %{MONTH} +%{MONTHDAY} %{TIME} %{YEAR}) \[%{DATA:module_level}\] \[pid %{NUMBER:pid}:tid %{NUMBER:tid}\] \[%{DATA:node_id}\] %{GREEDYDATA:log_message}'
      }
    }
    # trim microseconds -> milliseconds so the date filter can parse it
    mutate { gsub => ["log_timestamp", "(:\d{2}\.\d{3})\d+", "\1"] }
    date  { match => ["log_timestamp", "EEE MMM dd HH:mm:ss.SSS yyyy", "EEE MMM d HH:mm:ss.SSS yyyy"] }
    mutate { add_field => { "log_type" => "dispatcher-error" } }
  }

  # =========================================================================
  #  AEM Java / error log  (*aemerror*)
  #  dd.MM.yyyy HH:mm:ss.SSS [nodeId] *LEVEL* [thread] logger message
  # =========================================================================
  else if "aemerror" in [path] {
    grok {
      match => { "message" =>
        '(?<log_timestamp>%{MONTHDAY}\.%{MONTHNUM}\.%{YEAR} %{TIME}) (?:\[%{DATA:node_id}\] )?\*%{LOGLEVEL:log_level}\* \[%{GREEDYDATA:thread}\] %{NOTSPACE:logger} %{GREEDYDATA:log_message}'
      }
    }
    date { match => ["log_timestamp", "dd.MM.yyyy HH:mm:ss.SSS"] }
    mutate { add_field => { "log_type" => "aem-error" } }

    # ---- Enrichment: Generate normalized log_signature -----------------------
    # Strips UUIDs, paths, and numbers so identical errors group together
    if [log_message] {
      mutate {
        copy => { "log_message" => "log_signature" }
      }
      mutate {
        gsub => [
          "log_signature", "[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}", "<UUID>",
          "log_signature", "(?:/[\w.\-:%]+){2,}", "<PATH>",
          "log_signature", "\b\d+\b", "#",
          "log_signature", "\s+", " "
        ]
      }
      # Trim trailing/leading whitespace
      mutate {
        strip => ["log_signature"]
      }
    }

    # ---- Enrichment: extract exception class from log_message ----------------
    #   e.g. "javax.jcr.RepositoryException: Unable to ..." -> "RepositoryException"
    if [log_message] {
      grok {
        match          => { "log_message" => "(?:%{JAVACLASS:error_class_fqcn})?" }
        tag_on_failure => []
      }
      if [error_class_fqcn] {
        grok {
          match          => { "error_class_fqcn" => "(?:.*\.)?(?<error_class>[A-Za-z]+)$" }
          tag_on_failure => []
        }
        mutate { remove_field => ["error_class_fqcn"] }
      }
    }

    # ---- Enrichment: flag events that contain stack traces -------------------
    if "\tat " in [message] or "\t... " in [message] {
      mutate { add_field => { "has_stacktrace" => "true" } }
    } else {
      mutate { add_field => { "has_stacktrace" => "false" } }
    }
  }

  # ---- Pull program / env / region / tier / pod out of the AEM node id ------
  #   e.g. cm-p12345-e6789-aem-author-86657cbb55-xrnzq
  #        cm-p7613-e12700-nld2-aem-publish-...   (region = nld2)
  if [node_id] {
    grok {
      match          => { "node_id" => "cm-p%{NUMBER:program_id}-e%{NUMBER:env_id}-(%{DATA:region}-)?aem-%{WORD:aem_tier}-%{NOTSPACE:pod}" }
      tag_on_failure => []
    }
  }

  # ---- Fallback: if the log lines carry no node id (e.g. your error.log),
  #      take the tier from the filename prefix (author-... / publish-...) ----
  if ![aem_tier] {
    if      "author"  in [path] { mutate { add_field => { "aem_tier" => "author" } } }
    else if "publish" in [path] { mutate { add_field => { "aem_tier" => "publish" } } }
  }

  # ---- Enrichment: extract short logger name and bundle name ---------------
  #   e.g. "org.apache.sling.event.impl.jobs.JobManagerImpl"
  #     -> logger_short = "JobManagerImpl"
  #     -> bundle_name  = "org.apache.sling"
  if [logger] {
    grok {
      match          => { "logger" => "(?:.*\.)?(?<logger_short>[A-Za-z0-9$_]+)$" }
      tag_on_failure => []
    }
    grok {
      match          => { "logger" => "(?<bundle_name>[a-z]+\.[a-z]+\.[a-z]+)" }
      tag_on_failure => []
    }
  }

  # ---- Enrichment: clean URL path (strip query string) ---------------------
  if [url] {
    grok {
      match          => { "url" => "(?<url_path>[^?#]+)" }
      tag_on_failure => []
    }
    # Extract the file extension from the URL path
    grok {
      match          => { "url_path" => "\.(?<url_extension>[a-zA-Z0-9]+)(?:/[^/]*)?$" }
      tag_on_failure => []
    }
  }

  # ---- Enrichment: response time buckets -----------------------------------
  if [response_time_ms] {
    if      [response_time_ms] > 2000 { mutate { add_field => { "response_time_bucket" => "very_slow (>2s)" } } }
    else if [response_time_ms] > 500  { mutate { add_field => { "response_time_bucket" => "slow (500ms-2s)" } } }
    else if [response_time_ms] > 100  { mutate { add_field => { "response_time_bucket" => "normal (100-500ms)" } } }
    else                              { mutate { add_field => { "response_time_bucket" => "fast (<100ms)" } } }
  }

  # ---- Tidy up: treat "-" placeholders as empty ----------------------------
  if [client_ip]  == "-" { mutate { remove_field => ["client_ip"] } }
  if [auth_user]  == "-" { mutate { remove_field => ["auth_user"] } }

  # ---- Group status codes into 2xx/3xx/4xx/5xx for easy charting -----------
  if [status] {
    if      [status] >= 500 { mutate { add_field => { "status_class" => "5xx" } } }
    else if [status] >= 400 { mutate { add_field => { "status_class" => "4xx" } } }
    else if [status] >= 300 { mutate { add_field => { "status_class" => "3xx" } } }
    else if [status] >= 200 { mutate { add_field => { "status_class" => "2xx" } } }
  }
}

output {
  elasticsearch {
    hosts => ["http://elasticsearch:9200"]
    # Produces indices like: aem-access-2026.07.12, dispatcher-2026.07.12, aem-error-2026.07.12 ...
    index => "%{log_type}-%{+YYYY.MM.dd}"
  }

  # Uncomment while testing to watch parsed events (and spot _grokparsefailure):
  # stdout { codec => rubydebug }
}